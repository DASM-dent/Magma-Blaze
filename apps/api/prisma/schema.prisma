generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         String         @default("CUSTOMER")
  phone        String?
  whatsapp     String?
  preferredContact String     @default("SYSTEM")
  country      String         @default("RD")
  region       String?
  language     String         @default("es")
  currency     String         @default("DOP")
  notifyOrders Boolean        @default(true)
  notifyPromos Boolean        @default(false)
  notifySupport Boolean       @default(true)
  notifyDrops  Boolean        @default(true)
  isVerified   Boolean        @default(false)
  twoFactorEmailEnabled Boolean @default(false)
  blocked      Boolean        @default(false)
  blockedReason String?
  failedLoginAttempts Int     @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  addresses    Address[]
  orders       Order[]
  orderEvents  OrderEvent[]
  wishlists    WishlistItem[]
  notifications Notification[]
  logs         AuditLog[]
  verificationCodes EmailVerificationCode[]
  paymentMethods PaymentMethod[]
  helpTickets  HelpTicket[]   @relation("TicketCustomer")
  assignedTickets HelpTicket[] @relation("TicketAssignee")
  helpMessages HelpTicketMessage[]
}

model Role {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  active      Boolean          @default(true)
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id         String   @id @default(cuid())
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])
  permission String

  @@unique([roleId, permission])
  @@index([permission])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  email     String
  purpose   String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([userId])
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  icon     String    @default("🕶️")
  imageUrl String?
  sortOrder Int      @default(0)
  products Product[]
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  price       Int
  priceUsd    Int      @default(0)
  cost        Int      @default(0)
  discountActive Boolean      @default(false)
  discountType   String       @default("NONE")
  discountValue  Int          @default(0)
  discountLabel  String?
  discountStartsAt DateTime?
  discountEndsAt   DateTime?
  imageUrl    String
  stock       Int             @default(0)
  lowStockThreshold Int       @default(5)
  status      String          @default("ACTIVE")
  views       Int             @default(0)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  wishlists   WishlistItem[]
  modelPhotos ModelPhoto[]
  inventoryMovements InventoryMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([discountActive])
  @@index([discountStartsAt])
  @@index([discountEndsAt])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  color     String?
  size      String?
  model     String?
  lens      String?
  price     Int?
  priceUsd  Int?
  stock     Int      @default(0)
  imageUrl  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  orderItems OrderItem[]
  inventoryMovements InventoryMovement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([active])
  @@index([sku])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, sortOrder])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  country   String
  province  String?
  city      String?
  line1     String
  zip       String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  label     String
  brand     String?
  last4     String?
  holderName String?
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ShippingZone {
  id        String  @id @default(cuid())
  country   String
  province  String?
  city      String?
  price     Int
  currency  String  @default("DOP")
  requiresConfirmation Boolean @default(false)
  active    Boolean @default(true)
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  status         String      @default("PENDING")
  shippingStatus String      @default("PENDIENTE")
  subtotal       Int
  discount       Int      @default(0)
  shipping       Int
  total          Int
  country        String
  currency       String   @default("DOP")
  salesChannel   String   @default("WEB")
  confirmationStatus String @default("UNCONFIRMED")
  inventoryCommitted Boolean @default(false)
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  promoCodeId    String?
  promoCode      PromoCode? @relation(fields: [promoCodeId], references: [id])
  paymentStatus  String   @default("PENDING")
  paymentProvider String?
  paymentReference String?
  customerPhone  String?
  awaitingCustomerApproval Boolean @default(false)
  customerDecisionAt DateTime?
  addressLine    String
  packageNote    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  deliveryPlace  String?
  driverName     String?
  driverPhone    String?
  shippingReference String?
  shippingInvoiceUrl String?
  shippingInvoicePdfUrl String?
  adminNote      String?
  items          OrderItem[]
  events         OrderEvent[]
  payments       PaymentTransaction[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([salesChannel])
  @@index([customerPhone])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([type])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  price     Int

  @@index([variantId])
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  type      String
  quantity  Int
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([variantId])
  @@index([type])
}

model PaymentTransaction {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  provider  String
  status    String
  amount    Int
  currency  String   @default("DOP")
  reference String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

model Drop {
  id          String   @id @default(cuid())
  title       String
  description String
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(false)
  lockedMode  Boolean  @default(false)
  modelPhotos ModelPhoto[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String   @default("SYSTEM")
  priority  String   @default("NORMAL")
  title     String
  body      String
  actionUrl String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([type])
}

model HelpTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("TicketCustomer", fields: [userId], references: [id])
  assignedToId String?
  assignedTo User?   @relation("TicketAssignee", fields: [assignedToId], references: [id])
  subject   String
  category  String   @default("GENERAL")
  status    String   @default("OPEN")
  priority  String   @default("NORMAL")
  preferredContact String @default("SYSTEM")
  contactPhone String?
  contactWhatsapp String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closedAt  DateTime?
  messages  HelpTicketMessage[]

  @@index([userId])
  @@index([assignedToId])
  @@index([status])
}

model HelpTicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    HelpTicket @relation(fields: [ticketId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  fromStaff Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([userId])
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String   @default("PERCENT")
  percent   Int      @default(0)
  amount    Int      @default(0)
  minSubtotal Int    @default(0)
  maxUses   Int?
  usedCount Int      @default(0)
  active    Boolean  @default(true)
  expiresAt DateTime?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  key   String @id
  value String
}

model ContentBlock {
  id        String   @id @default(cuid())
  area      String
  title     String
  subtitle  String?
  body      String?
  url       String?
  imageUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketingPopup {
  id                  String   @id @default(cuid())
  name                String
  title               String
  subtitle            String?
  body                String?
  imageUrl            String?
  backgroundColor     String   @default("#120d0a")
  overlayColor        String   @default("rgba(0,0,0,0.38)")
  titleColor          String   @default("#fff7ed")
  subtitleColor       String   @default("#fed7aa")
  bodyColor           String   @default("#ffffff")
  width               Int      @default(760)
  height              Int      @default(520)
  useImageDimensions  Boolean  @default(false)
  imageNaturalWidth   Int?
  imageNaturalHeight  Int?
  titleX              Int      @default(50)
  titleY              Int      @default(18)
  titleAlign          String   @default("center")
  subtitleX           Int      @default(50)
  subtitleY           Int      @default(30)
  subtitleAlign       String   @default("center")
  bodyX               Int      @default(50)
  bodyY               Int      @default(58)
  bodyAlign           String   @default("center")
  buttonsX            Int      @default(50)
  buttonsY            Int      @default(82)
  buttonsAlign        String   @default("center")
  primaryLabel        String   @default("Ver mas")
  primaryAction       String   @default("LINK")
  primaryUrl          String?
  primaryBgColor      String   @default("#ff6a00")
  primaryTextColor    String   @default("#111111")
  secondaryLabel      String?
  secondaryAction     String   @default("CLOSE")
  secondaryUrl        String?
  secondaryBgColor    String   @default("transparent")
  secondaryTextColor  String   @default("#ffffff")
  delaySeconds        Int      @default(4)
  showOnce            Boolean  @default(true)
  isActive            Boolean  @default(false)
  startsAt            DateTime?
  endsAt              DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model StoreMetric {
  id        String   @id @default(cuid())
  type      String
  label     String
  value     Int      @default(0)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  ip        String?
  createdAt DateTime @default(now())
}

model SecurityIpBan {
  id        String   @id @default(cuid())
  ip        String   @unique
  hits      Int      @default(0)
  banned    Boolean  @default(false)
  reason    String?
  userAgent String?
  lastPath  String?
  bannedAt  DateTime?
  bannedUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([banned])
  @@index([bannedUntil])
}


model ModelPhoto {
  id        String   @id @default(cuid())
  dropId    String?
  drop      Drop?    @relation(fields: [dropId], references: [id], onDelete: SetNull)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  imageUrl  String
  caption   String?
  tagX      Int      @default(50)
  tagY      Int      @default(50)
  tagDotSize Int     @default(24)
  tagLabelSize Int   @default(12)
  tagLabelOffsetX Int @default(0)
  tagLabelOffsetY Int @default(8)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  imageUrl  String?
  type      String   @default("NEWS")
  isPublished Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
